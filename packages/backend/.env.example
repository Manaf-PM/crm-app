# Base de données (PostgreSQL local via Docker)
DATABASE_URL=postgresql://crm:crm@localhost:5432/crm

# Serveur
PORT=3001
FRONTEND_URL=http://localhost:3000

# Email — Brevo SMTP
# Récupère ta clé sur https://app.brevo.com/settings/keys/smtp
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=ton.email@domaine.fr
BREVO_SMTP_KEY=xsmtp-xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="CRM App <noreply@mondomaine.fr>"

# SMS — Twilio (optionnel pour commencer)
# Récupère tes clés sur https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+33600000000
